FROM node:22-alpine AS ui-builder
WORKDIR /app/ui
COPY ui/package*.json ./
RUN npm install
COPY ui/ ./
RUN npm run build

FROM golang:1.23-alpine AS go-builder
WORKDIR /app/controller
RUN apk add --no-cache git
ENV GOPROXY=direct
COPY controller/go.mod controller/go.sum* ./
RUN go mod download
COPY controller/ ./
RUN go build -o /out/nyxgate-controller ./cmd/nyxgate-controller

FROM golang:1.23-alpine AS agent-builder
WORKDIR /app/agent
RUN apk add --no-cache git
ENV GOPROXY=direct
COPY agent/go.mod agent/go.sum* ./
RUN go mod download
COPY agent/ ./
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/nyxgate-agent-linux-amd64 ./cmd/nyxgate-agent

FROM alpine:3.20
RUN adduser -D -H -u 10001 nyxgate && \
    mkdir -p /app/ui-dist /app/downloads /var/lib/nyxgate/certs && \
    chown -R nyxgate:nyxgate /app /var/lib/nyxgate
WORKDIR /app
COPY --from=go-builder /out/nyxgate-controller /usr/local/bin/nyxgate-controller
COPY --from=agent-builder /out/nyxgate-agent-linux-amd64 /app/downloads/nyxgate-agent-linux-amd64
COPY --from=ui-builder /app/ui/dist /app/ui-dist
EXPOSE 8443
ENV NYXGATE_LISTEN_ADDR=:8443 \
    NYXGATE_UI_BUILD_PATH=/app/ui-dist \
    NYXGATE_CERT_DIR=/var/lib/nyxgate/certs
USER nyxgate
ENTRYPOINT ["/usr/local/bin/nyxgate-controller"]
